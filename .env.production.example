# Production Environment Variables Template
# Copy this file and fill in your actual production values

# ==========================================
# FRONTEND (Vercel)
# ==========================================
# Set these in Vercel Dashboard > Settings > Environment Variables

AUTH_URL=https://your-auth-server.onrender.com
CHATBOT_API_URL=https://your-backend.onrender.com

# ==========================================
# BACKEND (Render - FastAPI)
# ==========================================
# Set these in Render Dashboard > Environment

# LLM Provider
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Vector Database (Qdrant Cloud)
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Conversation Database (Neon Postgres)
NEON_CONNECTION_STRING=postgresql://user:password@host/database?sslmode=require

# CORS - Include your Vercel domain
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Optional Config
LOG_LEVEL=INFO
CHUNK_SIZE=512
CHUNK_OVERLAP=128
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.7

# ==========================================
# AUTH SERVER (Render - Node.js)
# ==========================================
# Set these in Render Dashboard > Environment

# Database (Separate Postgres for auth - can be same Neon instance, different DB)
DATABASE_URL=postgresql://user:password@host/auth_db?sslmode=require

# Better Auth Configuration
BETTER_AUTH_SECRET=your_random_secret_here_min_32_chars
BETTER_AUTH_URL=https://your-auth-server.onrender.com

# OAuth Providers
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# CORS - Include your Vercel domain
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Node Environment
NODE_ENV=production
